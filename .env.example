# Conexión a Neon (Postgres). Coge la URL desde el dashboard de Neon.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Contraseña del panel admin (la pones tú, solo tú la sabes)
ADMIN_PASSWORD="cambia_esto_por_algo_seguro"

# Secreto para firmar la cookie de sesión admin (genera uno aleatorio largo)
ADMIN_SESSION_SECRET="genera_un_string_aleatorio_de_al_menos_32_caracteres"

# Fecha de bloqueo de porras (ISO 8601). Por defecto: arranque del Mundial.
LOCK_DATE="2026-06-11T17:00:00.000Z"

# ─── Email (Gmail SMTP vía Nodemailer) ───────────────────────────────────────
# Cuenta de Gmail (preferiblemente secundaria) desde la que se envían los
# emails de confirmación de porra.
SMTP_USER="tucuentasecundaria@gmail.com"
# "Contraseña de aplicación" de 16 caracteres generada en
# https://myaccount.google.com/apppasswords (requiere verificación en 2 pasos).
# NO es la contraseña normal de la cuenta.
SMTP_PASSWORD="contraseña_de_aplicacion_de_16_caracteres"

# URL base pública del sitio, para construir el enlace mágico absoluto del email.
# En local cae a http://localhost:3000 si no se define.
NEXT_PUBLIC_SITE_URL="https://porra-amigos.vercel.app"
